generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  professional
  auxiliary
}

enum AppointmentStatus {
  programada
  cancelada
  asistio
  no_asistio
}

enum TreatmentStatus {
  planificado
  en_proceso
  finalizado
  cancelado
}

enum ClinicalImageType {
  imagen
  radiografia
}

model Clinic {
  id             String          @id @default(uuid()) @db.Uuid
  name           String
  slug           String          @unique
  logoUrl        String?         @map("logo_url")
  isActive       Boolean         @default(true) @map("is_active")
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  users          User[]
  patients       Patient[]
  appointments   Appointment[]
  treatments     Treatment[]
  clinicalImages ClinicalImage[]
  income         Income[]
  expenses       Expense[]
  purchases      Purchase[]

  @@map("clinics")
}

model User {
  id                  String               @id @default(uuid()) @db.Uuid
  clinicId            String               @map("clinic_id") @db.Uuid
  username            String               @unique
  name                String?
  email               String               @unique
  emailVerified       DateTime?            @map("email_verified") @db.Timestamptz(6)
  image               String?
  passwordHash        String               @map("password_hash")
  role                UserRole
  isActive            Boolean              @default(true) @map("is_active")
  createdAt           DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  clinic              Clinic               @relation(fields: [clinicId], references: [id])
  accounts            Account[]
  sessions            Session[]
  passwordResetTokens PasswordResetToken[]
  appointmentsCreated Appointment[]        @relation("AppointmentCreatedBy")
  imagesUploaded      ClinicalImage[]      @relation("ClinicalImageUploadedBy")
  incomeCreated       Income[]             @relation("IncomeCreatedBy")
  expensesCreated     Expense[]            @relation("ExpenseCreatedBy")
  purchasesCreated    Purchase[]           @relation("PurchaseCreatedBy")

  @@index([clinicId])
  @@index([clinicId, role])
  @@map("users")
}

model Account {
  id                String  @id @default(uuid()) @db.Uuid
  userId            String  @map("user_id") @db.Uuid
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refreshToken      String? @map("refresh_token") @db.Text
  accessToken       String? @map("access_token") @db.Text
  expiresAt         Int?    @map("expires_at")
  tokenType         String? @map("token_type")
  scope             String?
  idToken           String? @map("id_token") @db.Text
  sessionState      String? @map("session_state")
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id") @db.Uuid
  expires      DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime @db.Timestamptz(6)

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  token     String    @unique
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model Patient {
  id             String          @id @default(uuid()) @db.Uuid
  clinicId       String          @map("clinic_id") @db.Uuid
  documentType   String          @map("document_type")
  documentNumber String          @map("document_number")
  firstName      String          @map("first_name")
  lastName       String          @map("last_name")
  phone          String?
  email          String?
  notes          String?         @db.Text
  isActive       Boolean         @default(true) @map("is_active")
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  clinic         Clinic          @relation(fields: [clinicId], references: [id])
  appointments   Appointment[]
  treatments     Treatment[]
  clinicalImages ClinicalImage[]
  income         Income[]

  @@unique([clinicId, documentType, documentNumber])
  @@index([clinicId])
  @@index([clinicId, lastName, firstName])
  @@map("patients")
}

model Appointment {
  id        String            @id @default(uuid()) @db.Uuid
  clinicId  String            @map("clinic_id") @db.Uuid
  patientId String            @map("patient_id") @db.Uuid
  createdBy String            @map("created_by") @db.Uuid
  title     String
  startAt   DateTime          @map("start_at") @db.Timestamptz(6)
  endAt     DateTime          @map("end_at") @db.Timestamptz(6)
  status    AppointmentStatus @default(programada)
  notes     String?           @db.Text
  createdAt DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  clinic    Clinic            @relation(fields: [clinicId], references: [id])
  patient   Patient           @relation(fields: [patientId], references: [id])
  creator   User              @relation("AppointmentCreatedBy", fields: [createdBy], references: [id])

  @@index([clinicId, startAt])
  @@index([clinicId, patientId])
  @@index([createdBy])
  @@map("appointments")
}

model Treatment {
  id             String          @id @default(uuid()) @db.Uuid
  clinicId       String          @map("clinic_id") @db.Uuid
  patientId      String          @map("patient_id") @db.Uuid
  name           String
  description    String?         @db.Text
  tooth          String?
  status         TreatmentStatus @default(planificado)
  startedAt      DateTime?       @map("started_at") @db.Date
  completedAt    DateTime?       @map("completed_at") @db.Date
  notes          String?         @db.Text
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  clinic         Clinic          @relation(fields: [clinicId], references: [id])
  patient        Patient         @relation(fields: [patientId], references: [id])
  clinicalImages ClinicalImage[]

  @@index([clinicId, patientId])
  @@index([clinicId, status])
  @@map("treatments")
}

model ClinicalImage {
  id          String            @id @default(uuid()) @db.Uuid
  clinicId    String            @map("clinic_id") @db.Uuid
  patientId   String            @map("patient_id") @db.Uuid
  treatmentId String?           @map("treatment_id") @db.Uuid
  url         String
  type        ClinicalImageType
  description String?
  takenAt     DateTime?         @map("taken_at") @db.Date
  uploadedBy  String            @map("uploaded_by") @db.Uuid
  createdAt   DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  clinic      Clinic            @relation(fields: [clinicId], references: [id])
  patient     Patient           @relation(fields: [patientId], references: [id])
  treatment   Treatment?        @relation(fields: [treatmentId], references: [id])
  uploader    User              @relation("ClinicalImageUploadedBy", fields: [uploadedBy], references: [id])

  @@index([clinicId, patientId])
  @@index([clinicId, treatmentId])
  @@index([uploadedBy])
  @@map("clinical_images")
}

model Income {
  id        String   @id @default(uuid()) @db.Uuid
  clinicId  String   @map("clinic_id") @db.Uuid
  patientId String?  @map("patient_id") @db.Uuid
  date      DateTime @db.Date
  concept   String
  amount    Decimal  @db.Decimal(12, 2)
  notes     String?  @db.Text
  createdBy String   @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  clinic    Clinic   @relation(fields: [clinicId], references: [id])
  patient   Patient? @relation(fields: [patientId], references: [id])
  creator   User     @relation("IncomeCreatedBy", fields: [createdBy], references: [id])

  @@index([clinicId, date])
  @@index([clinicId, patientId])
  @@index([createdBy])
  @@map("income")
}

model Expense {
  id        String   @id @default(uuid()) @db.Uuid
  clinicId  String   @map("clinic_id") @db.Uuid
  date      DateTime @db.Date
  concept   String
  amount    Decimal  @db.Decimal(12, 2)
  category  String?
  notes     String?  @db.Text
  createdBy String   @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  clinic    Clinic   @relation(fields: [clinicId], references: [id])
  creator   User     @relation("ExpenseCreatedBy", fields: [createdBy], references: [id])

  @@index([clinicId, date])
  @@index([createdBy])
  @@map("expense")
}

model Purchase {
  id          String   @id @default(uuid()) @db.Uuid
  clinicId    String   @map("clinic_id") @db.Uuid
  date        DateTime @db.Date
  supplier    String
  description String
  amount      Decimal  @db.Decimal(12, 2)
  notes       String?  @db.Text
  createdBy   String   @map("created_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  clinic      Clinic   @relation(fields: [clinicId], references: [id])
  creator     User     @relation("PurchaseCreatedBy", fields: [createdBy], references: [id])

  @@index([clinicId, date])
  @@index([createdBy])
  @@map("purchases")
}
